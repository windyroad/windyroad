{
  "permissions": {
    "allow": [
      "*",
      "Bash",
      "Edit",
      "Edit(.claude/**)",
      "Write(.claude/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/project-health-check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/a11y-team-eval.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/a11y-enforce-edit.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/no-em-dash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/a11y-mark-reviewed.sh"
          }
        ]
      }
    ],
    "Stop": []
  },
  "enabledPlugins": {
    "wr-tdd@windyroad": true,
    "wr-c4@windyroad": true,
    "wr-wardley@windyroad": true,
    "wr-retrospective@windyroad": true,
    "wr-architect@windyroad": true,
    "wr-itil@windyroad": true,
    "wr-jtbd@windyroad": true,
    "wr-risk-scorer@windyroad": true,
    "wr-style-guide@windyroad": true,
    "wr-voice-tone@windyroad": true
  }
}
